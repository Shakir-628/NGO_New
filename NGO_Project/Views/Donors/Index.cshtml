@model List<NGO_Project.Donor>

@{
    Layout = "~/Views/Shared/_LayoutNGO.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --primary: #4f46e5;
        --primary-dark: #4338ca;
        --secondary: #10b981;
        --accent: #f59e0b;
        --dark: #111827;
        --light: #f9fafb;
        --white: #ffffff;
        --bg-grad: linear-gradient(135deg, #f0f4ff 0%, #e8f0fe 100%);
        --card-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
        --border-radius: 16px;
    }

    body {
        font-family: 'Outfit', sans-serif;
        background: var(--bg-grad) !important;
        color: var(--dark);
    }

    .tab-content {
        animation: fadeIn 0.8s ease-out;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .page-header h1 {
        font-size: 2.25rem;
        font-weight: 700;
        margin: 0;
        background: linear-gradient(90deg, var(--primary), #3b82f6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .content-section {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(12px);
        border-radius: var(--border-radius);
        padding: 2rem;
        box-shadow: var(--card-shadow);
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .search-container {
        margin-bottom: 1.5rem;
        position: relative;
    }

    .search-input {
        width: 100%;
        max-width: 400px;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        font-size: 1rem;
        background: #f9fafb;
        transition: all 0.2s;
    }

    .search-input:focus {
        outline: none;
        border-color: var(--primary);
        background: white;
        box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
    }

    .search-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
    }

    .donor-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

    .donor-table thead th {
        background: #f8fafc;
        padding: 1rem;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        border-bottom: 2px solid #e2e8f0;
        text-align: left;
    }

    .donor-table tbody td {
        padding: 1.25rem 1rem;
        border-bottom: 1px solid #f1f5f9;
        font-size: 0.95rem;
        vertical-align: middle;
    }

    .donor-table tr:hover td {
        background: #fdfeff;
    }

    .donor-name {
        font-weight: 700;
        color: var(--dark);
        font-size: 1.05rem;
    }

    .contact-info {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        font-size: 0.875rem;
        color: #6b7280;
    }

    .badge-type {
        background: #dcfce7;
        color: #16a34a;
        border-radius: 8px;
        padding: 4px 12px;
        font-size: 0.85rem;
        font-weight: 600;
        display: inline-block;
    }

    .btn-action {
        padding: 0.5rem 1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.875rem;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-view {
        background: #eef2ff;
        color: var(--primary);
    }

    .btn-view:hover {
        background: var(--primary);
        color: white;
        transform: translateY(-1px);
    }

    /* Modal Styling */
    .modal-bg {
        position: fixed;
        inset: 0;
        background: rgba(17, 24, 39, 0.7);
        backdrop-filter: blur(8px);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 2000;
        padding: 1.5rem;
    }

    .modal-content {
        background: var(--white);
        border-radius: 20px;
        width: 100%;
        max-width: 650px;
        padding: 2rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        position: relative;
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid #f1f5f9;
        padding-bottom: 1rem;
    }

    .modal-header h2 {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0;
        color: var(--dark);
    }

    .close-modal {
        background: none;
        border: none;
        font-size: 1.5rem;
        color: #9ca3af;
        cursor: pointer;
        transition: color 0.2s;
    }

    .close-modal:hover {
        color: var(--dark);
    }

    .donated-items-list {
        background: #f8fafc;
        border-radius: 12px;
        padding: 0;
        border: 1px solid #e2e8f0;
        min-height: 100px;
        margin-bottom: 1.5rem;
        overflow: hidden;
    }

    .details-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
    }

    .details-table th {
        background: #f1f5f9;
        padding: 12px 15px;
        text-align: left;
        font-weight: 600;
        color: #475569;
        border-bottom: 1px solid #e2e8f0;
    }

    .details-table td {
        padding: 12px 15px;
        border-bottom: 1px solid #f1f5f9;
        color: #1e293b;
    }

    .details-table tr:last-child td {
        border-bottom: none;
    }

    .item-name-cell {
        font-weight: 600;
        color: var(--primary);
    }

    .donated-item-tag {
        display: inline-block;
        background: white;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        margin: 0.25rem;
        border: 1px solid #e2e8f0;
        font-weight: 500;
        color: #475569;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }

    .qty-badge {
        background: #e0f2fe;
        color: #0369a1;
        padding: 2px 8px;
        border-radius: 6px;
        font-weight: 700;
    }

    .empty-state {
        text-align: center;
        color: #9ca3af;
        padding: 2rem;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="tab-content">
    <div class="page-header mt-4">
        <h1><i class="fas fa-hand-holding-heart me-2" style="color: var(--primary);"></i>Donor Database</h1>
        <p class="text-secondary">View and manage all contributors to your organization.</p>
    </div>

    <div class="content-section">
        <div class="search-container">
            <i class="fas fa-search search-icon"></i>
            <input type="text" id="donorSearch" class="search-input" placeholder="Search donors by name, email or phone..." />
        </div>

        <div style="overflow-x:auto;">
            <table id="donorTable" class="donor-table">
                <thead>
                    <tr>
                        <th>Donor Details</th>
                        <th>Donor Type</th>
                        <th>Last Activity</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var donor in Model)
                    {
                        <tr>
                            <td>
                                <div class="donor-name">@donor.FullName</div>
                                <div class="contact-info">
                                    <span><i class="fas fa-envelope me-1"></i> @donor.Email</span>
                                    <span><i class="fas fa-phone me-1"></i> @donor.PhoneNumber</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge-type">Individual</span>
                            </td>
                            <td style="color: #64748b;">
                                @(donor.CreatedDate.HasValue ? donor.CreatedDate.Value.ToString("MMM dd, yyyy") : "N/A")
                            </td>
                            <td>
                                <button class="btn-action btn-view viewItemsBtn" 
                                        data-id="@donor.DonorId"
                                        data-name="@donor.FullName">
                                    <i class="fas fa-eye"></i> View
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Donated Items Modal -->
<div class="modal-bg" id="itemsModal">
    <div class="modal-content animate__animated animate__zoomIn">
        <div class="modal-header">
            <h2 id="modalDonorName">Donation Details</h2>
            <button class="close-modal" id="closeModal">&times;</button>
        </div>
        <div class="donated-items-list" id="itemsList">
            <!-- Details Table will be injected here -->
        </div>
        <div style="text-align: right;">
            <button class="btn-action btn-view" style="width: 100%; justify-content: center;" id="modalCloseBtn">Close Window</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Live search
            $("#donorSearch").on("keyup", function () {
                var value = $(this).val().toLowerCase();
                $("#donorTable tbody tr").filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });

            // Open modal
            $(".viewItemsBtn").on("click", function () {
                var donorId = $(this).data("id");
                var name = $(this).data("name");

                $("#modalDonorName").text(name + "'s Donations");
                $("#itemsList").html('<div class="empty-state"><i class="fas fa-spinner fa-spin me-2"></i> Loading details...</div>');
                $("#itemsModal").css("display", "flex");

                $.ajax({
                    url: '/Donors/GetDonatedItems',
                    type: 'GET',
                    data: { id: donorId },
                    success: function (res) {
                        var html = "";
                        if (res.type === "detailed" && res.items.length > 0) {
                            html += '<table class="details-table">' +
                                    '<thead>' +
                                        '<tr>' +
                                            '<th>Item Name</th>' +
                                            '<th>Quantity</th>' +
                                            '<th>Unit</th>' +
                                            '<th>Date</th>' +
                                        '</tr>' +
                                    '</thead>' +
                                    '<tbody>';
                            
                            res.items.forEach(function(item) {
                                html += '<tr>' +
                                            '<td class="item-name-cell">' + item.ItemName + '</td>' +
                                            '<td><span class="qty-badge">' + (item.Quantity || 0) + '</span></td>' +
                                            '<td>' + (item.Unit || "-") + '</td>' +
                                            '<td style="color:#647280; font-size:0.85rem;">' + item.Date + '</td>' +
                                        '</tr>';
                            });
                            
                            html += '</tbody></table>';
                        } else if (res.type === "summary" && res.summary) {
                            html = '<div style="padding: 1.5rem;">' +
                                   '<div style="color: #64748b; font-size: 0.85rem; margin-bottom: 1rem; font-weight: 500;">' +
                                   '<i class="fas fa-history me-1"></i> Primary Donation Item:</div>';
                            
                            html += '<table class="details-table">' +
                                    '<thead><tr><th>Item Name</th><th>Quantity</th><th>Unit</th><th>Date</th></tr></thead>' +
                                    '<tbody>' +
                                        '<tr>' +
                                            '<td class="item-name-cell">' + res.summary.ItemName + '</td>' +
                                            '<td><span class="qty-badge">' + (res.summary.Quantity || 0) + '</span></td>' +
                                            '<td>' + (res.summary.Unit || "-") + '</td>' +
                                            '<td style="color:#647280; font-size:0.85rem;">' + res.summary.Date + '</td>' +
                                        '</tr>' +
                                    '</tbody></table>';
                            html += '</div>';
                        } else {
                            html = '<div class="empty-state"><i class="fas fa-info-circle me-1"></i> No individual items recorded for this donor.</div>';
                        }
                        $("#itemsList").html(html);
                    },
                    error: function () {
                        $("#itemsList").html('<div class="empty-state text-danger"><i class="fas fa-exclamation-triangle me-1"></i> Failed to load data.</div>');
                    }
                });
            });

            // Close modal
            $("#closeModal, #modalCloseBtn").on("click", function () {
                $("#itemsModal").hide();
            });

            $(window).on("click", function (event) {
                if ($(event.target).is("#itemsModal")) {
                    $("#itemsModal").hide();
                }
            });
        });
    </script>
}

